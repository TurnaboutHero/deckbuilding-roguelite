{
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "test": "vitest run",
    "build": "pnpm -r run build",
    "ci:sim": "tsx tools/sim/src/ci-smoke.ts",
    "sim:balance": "tsx tools/sim/src/balance-report.ts",
