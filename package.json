    "sim": "pnpm --filter @game/sim run cli",
    "dev": "pnpm --filter @game/ui run dev",
    "shot": "pnpm --filter @game/ui run shot"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "fast-check": "^3.23.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
